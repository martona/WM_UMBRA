#include <windows.h>
#include <commctrl.h>
#include "resource.h"

/////////////////////////////////////////////////////////////////////////////
// Menu
IDM_MAIN MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",               IDM_FILE_EXIT
    END
    POPUP "&Mode"
    BEGIN
        MENUITEM "Palette: Follow &System",  IDM_MODE_SYSTEM
        MENUITEM "Palette: Force &Dark",     IDM_MODE_DARK
        MENUITEM "Palette: Force &Light",    IDM_MODE_LIGHT
        MENUITEM SEPARATOR
        MENUITEM "Process-wide color &hook (Detours)", IDM_HOOK_TOGGLE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About umbra-hook",   IDM_HELP_ABOUT
    END
END

/////////////////////////////////////////////////////////////////////////////
// Frame window. Empty body: the toolbar, tab control and status bar are
// created programmatically in WM_INITDIALOG; the four pages are child dialogs
// hosted in the tab's display area.
IDD_FRAME DIALOGEX 0, 0, 520, 360
STYLE DS_SETFONT | DS_CENTER | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_CAPTION |
      WS_SYSMENU | WS_THICKFRAME | WS_CLIPCHILDREN | WS_OVERLAPPED | WS_VISIBLE
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "WM_UMBRA - color-path probe (umbra-hook)"
MENU IDM_MAIN
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
END

/////////////////////////////////////////////////////////////////////////////
// Tab A - raw user32 / GDI controls (GetSysColor + WM_CTLCOLOR*; hookable)
IDD_PAGE_A DIALOGEX 0, 0, 300, 190
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Source A - raw user32/GDI controls. These resolve color via GetSysColor + WM_CTLCOLOR*, so a hook reaches them.", -1, 7, 4, 286, 18
    GROUPBOX        "Buttons", IDC_A_GROUP, 7, 24, 150, 86
    PUSHBUTTON      "&Push Button", IDC_A_BTN, 14, 38, 64, 14
    AUTOCHECKBOX    "Check &one", IDC_A_CHK1, 14, 58, 120, 10
    AUTOCHECKBOX    "Check &two", IDC_A_CHK2, 14, 72, 120, 10
    AUTORADIOBUTTON "Radio &A", IDC_A_RAD1, 14, 88, 64, 10, WS_GROUP
    AUTORADIOBUTTON "Radio &B", IDC_A_RAD2, 84, 88, 64, 10
    LTEXT           "Single-line edit:", -1, 165, 24, 128, 8
    EDITTEXT        IDC_A_EDIT, 165, 34, 128, 12, ES_AUTOHSCROLL
    LTEXT           "Multi-line edit (select text for COLOR_HIGHLIGHT):", -1, 165, 50, 128, 16
    EDITTEXT        IDC_A_EDIT_MULTI, 165, 68, 128, 36, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL
    LTEXT           "Combo box:", -1, 7, 116, 150, 8
    COMBOBOX        IDC_A_COMBO, 7, 126, 150, 80, CBS_DROPDOWNLIST | WS_TABSTOP | WS_VSCROLL
    LTEXT           "List box:", -1, 165, 110, 128, 8
    LISTBOX         IDC_A_LIST, 165, 120, 128, 46, LBS_NOINTEGRALHEIGHT | LBS_NOTIFY | WS_BORDER | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Standalone scroll bar:", -1, 7, 146, 150, 8
    SCROLLBAR       IDC_A_SCROLL, 7, 156, 150, 12, SBS_HORZ
END

/////////////////////////////////////////////////////////////////////////////
// Tab B - export vs internal exhibit (two panels created in code)
IDD_PAGE_B DIALOGEX 0, 0, 300, 190
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Source B - does the call reach the exported API, or does user32 resolve the color internally? The two panels are identical today; a future hook on the export should darken only the left one.", -1, 7, 4, 286, 26
    LTEXT           "Left: EXPORT path - fills via GetSysColorBrush(COLOR_WINDOW).", IDC_B_LBL_EXPORT, 7, 32, 140, 18
    LTEXT           "Right: INTERNAL path - class background brush (COLOR_WINDOW+1), erased by user32.", IDC_B_LBL_INTERNAL, 153, 32, 140, 18
END

/////////////////////////////////////////////////////////////////////////////
// Tab C - uxtheme / comctl32 (theme-part drawn; dark look comes from the
// DarkMode_* theme class, not a color hook)
IDD_PAGE_C DIALOGEX 0, 0, 300, 190
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Source C - comctl32 over uxtheme. Painted from theme parts; expect these to stay light until the DarkMode_* theme class is applied.", -1, 7, 4, 286, 18
    CONTROL         "", IDC_C_LIST, "SysListView32", LVS_REPORT | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 7, 26, 150, 66
    CONTROL         "", IDC_C_TREE, "SysTreeView32", TVS_HASBUTTONS | TVS_HASLINES | TVS_LINESATROOT | WS_BORDER | WS_TABSTOP, 165, 26, 128, 66
    LTEXT           "Progress / Trackbar:", -1, 7, 96, 150, 8
    CONTROL         "", IDC_C_PROGRESS, "msctls_progress32", PBS_SMOOTH | WS_BORDER, 7, 106, 150, 10
    CONTROL         "", IDC_C_TRACK, "msctls_trackbar32", TBS_HORZ | TBS_AUTOTICKS | WS_TABSTOP, 7, 118, 150, 18
    LTEXT           "Spin:", -1, 165, 96, 40, 8
    EDITTEXT        IDC_C_SPINBUDDY, 165, 106, 40, 12, ES_NUMBER | WS_BORDER
    CONTROL         "", IDC_C_SPIN, "msctls_updown32", UDS_ALIGNRIGHT | UDS_SETBUDDYINT | UDS_ARROWKEYS | WS_TABSTOP, 205, 106, 12, 12
    CONTROL         "Project: <A HREF=""https://github.com/martona/WM_UMBRA"">github.com/martona/WM_UMBRA</A>", IDC_C_SYSLINK, "SysLink", WS_TABSTOP, 165, 124, 128, 16
    GROUPBOX        "Classic-path canaries (date picker / hotkey / IP)", IDC_C_CANARYGROUP, 7, 140, 286, 44
    CONTROL         "", IDC_C_DTP, "SysDateTimePick32", DTS_SHORTDATEFORMAT | WS_TABSTOP, 14, 156, 86, 14
    CONTROL         "", IDC_C_HOTKEY, "msctls_hotkey32", WS_BORDER | WS_TABSTOP, 108, 156, 70, 14
    CONTROL         "", IDC_C_IPADDR, "SysIPAddress32", WS_TABSTOP, 184, 156, 100, 14
END

/////////////////////////////////////////////////////////////////////////////
// Tab E - DirectUI (embedded ExplorerBrowser + modern file dialog; classic
// color dialog shown for source-A contrast). Browser created in code.
IDD_PAGE_E DIALOGEX 0, 0, 300, 190
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Source E - DirectUI (DUI70). Embedded Explorer view + modern file dialog are DirectUI. In Permissions, the 'Advanced' button opens the DirectUI ACE editor. Classic color dialog is source A, for contrast.", -1, 7, 4, 286, 26
    PUSHBUTTON      "Open &file dialog (DirectUI)...", IDC_E_BTN_FILEDLG, 7, 34, 135, 14
    PUSHBUTTON      "&Permissions (this .exe)...", IDC_E_BTN_PERMS, 146, 34, 147, 14
    PUSHBUTTON      "Classic &color dialog (comdlg32)...", IDC_E_BTN_COLORDLG, 7, 52, 160, 14
    LTEXT           "Embedded ExplorerBrowser (This PC):", IDC_E_HOSTLBL, 7, 70, 286, 8
END
